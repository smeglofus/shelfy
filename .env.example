# Backend app metadata
APP_NAME=Shelfy API
ENVIRONMENT=development

# Backend service connectivity
DATABASE_URL=postgresql+asyncpg://shelfy:shelfy@postgres:5432/shelfy
REDIS_URL=redis://redis:6379/0
CORS_ALLOWED_ORIGINS=["http://localhost:5173"]

# Authentication
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
SEED_ADMIN_ON_STARTUP=false

# Postgres bootstrap for local docker compose
POSTGRES_DB=shelfy
POSTGRES_USER=shelfy
POSTGRES_PASSWORD=shelfy

# MinIO local bootstrap credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=shelfy-images
MINIO_REGION=us-east-1

# Worker service connectivity
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Frontend app configuration
VITE_API_BASE_URL=http://localhost:8000

