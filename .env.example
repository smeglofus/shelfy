# Backend app metadata
APP_NAME=Shelfy API
ENVIRONMENT=development

# Backend service connectivity
DATABASE_URL=postgresql+asyncpg://shelfy:shelfy@postgres:5432/shelfy
REDIS_URL=redis://redis:6379/0

# Postgres bootstrap for local docker compose
POSTGRES_DB=shelfy
POSTGRES_USER=shelfy
POSTGRES_PASSWORD=shelfy

# MinIO local bootstrap credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Worker service connectivity
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
