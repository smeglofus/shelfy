# Shelfy — production environment template
# Copy to .env.prod.local and fill in real values:
#   cp .env.prod.example .env.prod.local
#
# NEVER commit .env.prod.local to git.

ENVIRONMENT=production

# ── Database ──────────────────────────────────────────
POSTGRES_DB=shelfy
POSTGRES_USER=shelfy
POSTGRES_PASSWORD=                          # generate: openssl rand -base64 32
DATABASE_URL=postgresql+asyncpg://shelfy:<POSTGRES_PASSWORD>@postgres:5432/shelfy

# ── Redis ─────────────────────────────────────────────
REDIS_PASSWORD=                             # generate: openssl rand -base64 32
REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379/0
CELERY_BROKER_URL=redis://:<REDIS_PASSWORD>@redis:6379/0
CELERY_RESULT_BACKEND=redis://:<REDIS_PASSWORD>@redis:6379/1

# ── Object storage (MinIO) ────────────────────────────
MINIO_ROOT_USER=                            # generate: openssl rand -hex 16
MINIO_ROOT_PASSWORD=                        # generate: openssl rand -base64 32
MINIO_ACCESS_KEY=                           # same as MINIO_ROOT_USER
MINIO_SECRET_KEY=                           # same as MINIO_ROOT_PASSWORD
MINIO_BUCKET=shelfy-images
MINIO_BACKUP_BUCKET=shelfy-backups
MINIO_REGION=us-east-1
MINIO_ENDPOINT=http://minio:9000

# ── Auth ──────────────────────────────────────────────
JWT_SECRET_KEY=                             # generate: openssl rand -base64 64
TRUST_PROXY_HEADERS=true

# ── CORS (set to your production domain) ──────────────
CORS_ALLOWED_ORIGINS=["https://your-domain.example.com"]

# ── Observability ─────────────────────────────────────
SENTRY_DSN=
VITE_SENTRY_DSN=

# ── Stripe billing ────────────────────────────────────
STRIPE_SECRET_KEY=                          # sk_live_...
STRIPE_WEBHOOK_SECRET=                      # whsec_...
STRIPE_PRICE_ID_PRO=                        # price_...
STRIPE_PRICE_ID_LIBRARY=                    # price_...

# ── App URL (used for email links, Stripe redirects) ──
APP_URL=https://your-domain.example.com

# ── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=                             # re_...
EMAIL_FROM_ADDRESS=Shelfy <noreply@your-domain.example.com>

# ── Housekeeping ──────────────────────────────────────
BACKUP_KEEP_DAYS=30
STRIPE_EVENTS_KEEP_DAYS=90

# ── Rate limits ───────────────────────────────────────
RATE_LIMIT_LOGIN=20/minute
RATE_LIMIT_REFRESH=30/minute
RATE_LIMIT_TELEMETRY_FRONTEND_ERROR=15/minute
